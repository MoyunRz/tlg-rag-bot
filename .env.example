APP_HOST=127.0.0.1
APP_PORT=4000
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=replace-with-your-bot-token
CHROMA_URL=http://127.0.0.1:8600
# Use a fresh collection when switching embedding model families.
CHROMA_COLLECTION=tlg-rag-bot-model2vec

# For fully offline/local deployment, replace this with a local model directory.
KB_EMBEDDING_MODEL=minishlab/potion-multilingual-128M
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=100
KB_EMBED_BATCH_SIZE=1
KB_MAX_UPLOAD_BYTES=10485760

# If OCR_ENABLED is omitted, setting OCR_API_KEY auto-enables OCR.
# OCR_ENABLED=true
OCR_BASE_URL=https://api.xiaomimimo.com/anthropic
OCR_API_KEY=replace-with-your-mimo-api-key
OCR_MODEL=mimo-v2.5
OCR_TIMEOUT_MS=60000
OCR_MAX_TOKENS=4096

LLM_PROVIDER=minimax
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_API_KEY=replace-with-your-minimax-api-key
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT_MS=30000
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

RAG_TOP_K=4
# RAG_SCORE_THRESHOLD=0.3
RAG_MAX_CONTEXT_CHARS=4000
